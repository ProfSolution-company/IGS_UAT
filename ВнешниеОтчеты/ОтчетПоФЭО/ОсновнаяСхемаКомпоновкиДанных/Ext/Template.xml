	уатРасходГСМнаТСОбороты.Регистратор КАК Регистратор
ПОМЕСТИТЬ ВТ_ДанныеГСМ
ИЗ
	РегистрНакопления.уатРасходГСМнаТС.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Регистратор, ) КАК уатРасходГСМнаТСОбороты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ДанныеФЭО.Проект КАК Проект,
	ВТ_ДанныеФЭО.Местонахождение КАК Местонахождение,
	ВТ_ДанныеФЭО.Блок КАК Блок,
	уатТС.ГаражныйНомер КАК ПодвижнойСоставКод,
	уатТС.Наименование КАК ПодвижнойСоставКодНаименование,
	уатТС.ГосударственныйНомер КАК ПодвижнойСоставГосударственныйНомер,
	уатТипыТС.Код КАК ШифрКод,
	уатТипыТС.Наименование КАК ШифрНаименование,
	уатМоделиТС.Наименование КАК МаркаШассиНаименование,
	ВТ_ДанныеФЭО.Водитель КАК ВодительФИО,
	Контрагенты.Код КАК ЗаказчикКод,
	Контрагенты.Наименование КАК ЗаказчикНаименование,
	ДоговорыКонтрагентов.Код КАК ДоговорКод,
	ДоговорыКонтрагентов.Наименование КАК ДоговорНаименование,
	ВТ_ДанныеФЭО.ВидТарифа КАК ВидТарифа,
	ВТ_ДанныеФЭО.Тариф КАК Тариф,
	СУММА(ВТ_ДанныеФЭО.ДниКонсервацииОборот) КАК ДниКонсервации,
	СУММА(ВТ_ДанныеФЭО.ВыработкаЧасовОборот) КАК ВыработкаЧасов,
	СУММА(ВТ_ДанныеФЭО.ВыработкаКмОборот) КАК ВыработкаКм,
	СУММА(ВТ_ДанныеФЭО.ЧасыСПООборот) КАК ЧасыСПО,
	СУММА(ВТ_ДанныеФЭО.КоличествоРейсовОборот) КАК КоличествоРейсовОборот,
	СУММА(ВТ_ДанныеФЭО.ДоходЗаПеревезенныйГрузтТКмОборот) КАК ДоходЗаПеревезенныйГрузтТКм,
	СУММА(ВТ_ДанныеФЭО.ДоходПоЧасамРаботыОборот) КАК ДоходПоЧасамРаботы,
	СУММА(ВТ_ДанныеФЭО.ДоходПоЧасамДежурстваОборот) КАК ДоходПоЧасамДежурства,
	СУММА(ВТ_ДанныеФЭО.ДоходПоДнямКонсервацииОборот) КАК ДоходПоДнямКонсервации,
	СУММА(ЕСТЬNULL(ВТ_ДанныеГСМ.РасходПоФактуОборот, 0)) КАК ГСМКоличествоЛ,
	СУММА(ЕСТЬNULL(ВТ_ДанныеГСМ.РасходПоФактуОборот * уатНоменклатураГСМ.Плотность, 0)) КАК ГСМКоличествоТН
ИЗ
	ВТ_ДанныеФЭО КАК ВТ_ДанныеФЭО
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеГСМ КАК ВТ_ДанныеГСМ
		ПО (ВТ_ДанныеГСМ.Регистратор ССЫЛКА Документ.уатПутевойЛист)
			И (ВТ_ДанныеГСМ.Регистратор = ВТ_ДанныеФЭО.Регистратор)
			И (ВТ_ДанныеГСМ.ТС = ВТ_ДанныеФЭО.ТранспортноеСредство)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.уатТС КАК уатТС
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.уатТипыТС КАК уатТипыТС
			ПО уатТС.ТипТС = уатТипыТС.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.уатМоделиТС КАК уатМоделиТС
				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.уатНоменклатураГСМ КАК уатНоменклатураГСМ
				ПО (уатНоменклатураГСМ.Номенклатура = уатМоделиТС.ОсновноеТопливо)
			ПО уатТС.Модель = уатМоделиТС.Ссылка
		ПО ВТ_ДанныеФЭО.ТранспортноеСредство = уатТС.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		ПО ВТ_ДанныеФЭО.Заказчики = Контрагенты.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		ПО ВТ_ДанныеФЭО.Договор = ДоговорыКонтрагентов.Ссылка

СГРУППИРОВАТЬ ПО
	ВТ_ДанныеФЭО.Проект,
	ВТ_ДанныеФЭО.Местонахождение,
	ВТ_ДанныеФЭО.Блок,
	уатТС.ГаражныйНомер,
	уатТС.Наименование,
	уатТС.ГосударственныйНомер,
	уатТипыТС.Код,
	уатТипыТС.Наименование,
	уатМоделиТС.Наименование,
	ВТ_ДанныеФЭО.Водитель,
	Контрагенты.Код,
	Контрагенты.Наименование,
	ДоговорыКонтрагентов.Код,
	ДоговорыКонтрагентов.Наименование,
	ВТ_ДанныеФЭО.ВидТарифа,
	ВТ_ДанныеФЭО.Тариф</query>
	</dataSet>
	<calculatedField>
		<dataPath>ДоходПоПутевымЛистам</dataPath>
		<expression>ДоходПоЧасамРаботы + ДоходПоЧасамДежурства + ДоходПоДнямКонсервации +  ДоходЗаПеревезенныйГрузтТКм</expression>
